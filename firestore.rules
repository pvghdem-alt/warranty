rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidWarranty(data) {
      return data.projectName is string && data.projectName.size() > 0 && data.projectName.size() <= 200 &&
             data.vendor is string && data.vendor.size() <= 200 &&
             data.expiryDate is timestamp &&
             data.deposit is number && data.deposit >= 0 &&
             data.issueRemark is string && data.issueRemark.size() <= 1000 &&
             (!data.keys().hasAny(['warrantyScope']) || (data.warrantyScope is string && data.warrantyScope.size() <= 2000)) &&
             data.isRefunded is bool &&
             data.hasIssue is bool &&
             (data.keys().hasAll(['projectName', 'vendor', 'expiryDate', 'deposit', 'isRefunded', 'hasIssue']) && data.keys().size() >= 6);
    }

    function isValidIssue(data) {
      return data.issueName is string && data.issueName.size() > 0 && data.issueName.size() <= 200 &&
             (!data.keys().hasAny(['vendorCompany']) || (data.vendorCompany is string && data.vendorCompany.size() <= 200)) &&
             (!data.keys().hasAny(['status']) || (data.status is string && data.status in ['未處理', '維修中', '待料中', '待確認', '已完成'])) &&
             (!data.keys().hasAny(['returnReason']) || (data.returnReason is string && data.returnReason.size() <= 500)) &&
             (!data.keys().hasAny(['involvedVendors']) || (data.involvedVendors is list && data.involvedVendors.size() <= 50)) &&
             (!data.keys().hasAny(['vendorReply']) || (data.vendorReply is string && data.vendorReply.size() <= 1000)) &&
             (!data.keys().hasAny(['estRepairTime']) || (data.estRepairTime is string && data.estRepairTime.size() <= 100)) &&
             (!data.keys().hasAny(['hasUnreadReply']) || (data.hasUnreadReply is bool)) &&
             (!data.keys().hasAny(['photoUrls']) || (data.photoUrls is list && data.photoUrls.size() <= 10)) &&
             (!data.keys().hasAny(['completionPhotoUrls']) || (data.completionPhotoUrls is list && data.completionPhotoUrls.size() <= 10)) &&
             data.warrantyId is string && data.warrantyId.size() <= 128 && data.warrantyId.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /warranties/{warrantyId} {
      allow get: if isValidId(warrantyId);
      allow list: if true; 
      
      allow create: if isValidId(warrantyId) && 
                      isValidWarranty(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
      
      allow update: if isValidId(warrantyId) &&
                      isValidWarranty(incoming()) &&
                      (!existing().keys().hasAny(['createdAt']) || incoming().createdAt == existing().createdAt) &&
                      (!incoming().keys().hasAny(['updatedAt']) || incoming().updatedAt == request.time);
      
      allow delete: if isValidId(warrantyId);
    }

    match /issues/{issueId} {
      allow get: if isValidId(issueId);
      allow list: if true;
      allow create: if isValidId(issueId) && isValidIssue(incoming()) && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isValidId(issueId) && isValidIssue(incoming()) && 
                      (!existing().keys().hasAny(['createdAt']) || incoming().createdAt == existing().createdAt) && 
                      (!incoming().keys().hasAny(['updatedAt']) || incoming().updatedAt == request.time);
      allow delete: if isValidId(issueId);
    }
    match /vendorSettings/{vendorName} {
      allow read: if true;
      allow write: if true;
    }
  }
}
